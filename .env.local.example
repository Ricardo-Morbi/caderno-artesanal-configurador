# Supabase — obter em: https://supabase.com/dashboard → projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...chave_anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...chave_service_role...

# Admin — senha para acessar /admin
ADMIN_PASSWORD=sua_senha_secreta_aqui
# Token = base64 da senha (ou defina um hash personalizado)
ADMIN_PASSWORD_HASH=

# WhatsApp — número com código do país (sem + ou espaços)
# Ex: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMERO=5511999999999
